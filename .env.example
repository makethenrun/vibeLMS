# ---------------------------------------------------------------------------
# pLMS environment variables
# Copy this file to `.env.local` and fill in the values for THIS instance.
# Each tutor/customer runs their own Supabase project — these values are unique
# per deployment. Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Supabase project URL (Supabase Dashboard → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Project Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service-role key (Project Settings → API → service_role secret)
# SERVER-ONLY. Never expose to the browser. Used for trusted server-side queries
# because pLMS uses its own auth layer instead of Supabase Auth + RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Name of the Supabase Storage bucket used for materials and homework files.
# Create it in the Supabase Dashboard → Storage (see README).
SUPABASE_STORAGE_BUCKET=plms

# Secret used to sign session JWTs. Generate one with:
#   openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Session lifetime in seconds (default: 7 days).
AUTH_SESSION_MAX_AGE=604800
